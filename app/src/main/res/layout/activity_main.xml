<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scroll_main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintWidth_max="480dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_iptitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3DS IP"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <EditText
                    android:id="@+id/et_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ems="8"
                    android:hint="Input 3ds IP Address"
                    android:inputType="text"
                    android:text="192.168.50.143"
                    app:layout_constraintStart_toStartOf="@+id/tv_iptitle"
                    app:layout_constraintTop_toBottomOf="@id/tv_iptitle"/>

                <Button
                    android:id="@+id/bt_save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bt_txt_save"
                    android:layout_marginLeft="20dp"
                    android:textAllCaps="false"
                    app:layout_constraintStart_toEndOf="@id/et_ip"
                    app:layout_constraintBottom_toBottomOf="@id/et_ip"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/line1"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#FFCCCCCC"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/group_ip"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_invert"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"
                app:layout_constraintTop_toBottomOf="@id/line1">

                <TextView
                    android:id="@+id/tv_invert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_mappingswap"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_invertAB"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A⇌B"
                    android:layout_marginTop="10dp"
                    app:layout_constraintStart_toStartOf="@+id/tv_invert"
                    app:layout_constraintTop_toBottomOf="@id/tv_invert" />

                <Switch
                    android:id="@+id/switch_invertXY"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X⇌Y"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/switch_invertAB" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/line2"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#FFCCCCCC"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/group_invert"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_turbo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"
                app:layout_constraintTop_toBottomOf="@id/line2">

                <TextView
                    android:id="@+id/tv_turbo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_turbo"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_turbo_A"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  A"
                    android:layout_marginTop="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_turbo" />

                <Switch
                    android:id="@+id/switch_turbo_B"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  B"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/switch_turbo_A" />

                <Switch
                    android:id="@+id/switch_turbo_X"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  X"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/switch_turbo_A" />

                <Switch
                    android:id="@+id/switch_turbo_Y"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Y"
                    android:layout_marginTop="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/switch_turbo_A" />

                <Switch
                    android:id="@+id/switch_turbo_L"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  L"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/switch_turbo_Y" />

                <Switch
                    android:id="@+id/switch_turbo_R"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  R"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/switch_turbo_Y" />

                <Switch
                    android:id="@+id/switch_turbo_ZL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZL"
                    android:layout_marginTop="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/switch_turbo_Y" />

                <Switch
                    android:id="@+id/switch_turbo_ZR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZR"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/switch_turbo_ZL" />

                <Button
                    android:id="@+id/bt_disableturbo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bt_txt_disableAllTurbo"
                    app:layout_constraintStart_toEndOf="@id/switch_turbo_ZR"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/switch_turbo_R"
                    app:layout_constraintBottom_toBottomOf="@+id/switch_turbo_ZL"
                    android:textAllCaps="false"/>

                <TextView
                    android:id="@+id/tv_interval_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/turbo_interval_title"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/switch_turbo_ZL" />

                <SeekBar
                    android:id="@+id/sb_turbo_interval"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:min="50"
                    android:max="500"
                    android:progress="60"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tv_turbo_interval"
                    app:layout_constraintTop_toBottomOf="@id/tv_interval_title" />

                <TextView
                    android:id="@+id/tv_turbo_interval"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#FF666666"
                    android:gravity="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/sb_turbo_interval"
                    app:layout_constraintBottom_toBottomOf="@id/sb_turbo_interval" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/line3"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#FFCCCCCC"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/group_turbo"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_specialbt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"
                app:layout_constraintTop_toBottomOf="@+id/line3">

                <TextView
                    android:id="@+id/tv_specialbt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_spBtmap"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sw_txt_home"
                    android:layout_marginTop="10dp"
                    app:layout_constraintEnd_toEndOf="@id/switch_shut"
                    app:layout_constraintTop_toBottomOf="@id/tv_specialbt" />

                <EditText
                    android:id="@+id/et_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/et_home"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textIsSelectable="true"
                    app:layout_constraintStart_toEndOf="@id/switch_home"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_specialbt"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sw_txt_power"
                    android:layout_marginTop="20dp"
                    app:layout_constraintEnd_toEndOf="@id/switch_shut"
                    app:layout_constraintTop_toBottomOf="@id/switch_home" />

                <EditText
                    android:id="@+id/et_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/et_share"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textIsSelectable="true"
                    app:layout_constraintStart_toEndOf="@id/switch_power"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_home"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_shut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sw_txt_poweroff"
                    android:layout_marginTop="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/switch_power" />

                <EditText
                    android:id="@+id/et_shut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/et_l3r3"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textIsSelectable="true"
                    app:layout_constraintStart_toEndOf="@id/switch_shut"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_power"
                    tools:ignore="MissingConstraints" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <Button
                android:id="@+id/bt_offScr"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="30dp"
                android:text="@string/bt_txt_scroff"
                android:textAllCaps="false"
                app:layout_constraintTop_toBottomOf="@+id/group_specialbt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
