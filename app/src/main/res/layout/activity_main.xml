<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scroll_main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintWidth_max="480dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_iptitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3DS IP"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <EditText
                    android:id="@+id/et_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ems="8"
                    android:hint="Input 3ds IP Address"
                    android:inputType="text"
                    android:text="192.168.50.143"
                    app:layout_constraintStart_toStartOf="@+id/tv_iptitle"
                    app:layout_constraintTop_toBottomOf="@id/tv_iptitle"/>

                <Button
                    android:id="@+id/bt_save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bt_txt_save"
                    android:layout_marginLeft="20dp"
                    android:textAllCaps="false"
                    app:layout_constraintStart_toEndOf="@id/et_ip"
                    app:layout_constraintBottom_toBottomOf="@id/et_ip"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/line1"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#FFCCCCCC"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/group_ip"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_keymap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"
                app:layout_constraintTop_toBottomOf="@id/line1">

                <TextView
                    android:id="@+id/tv_keymap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_keymap"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <!-- Mode toggle -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_mode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:tabIndicatorColor="?attr/colorPrimary"
                    app:tabSelectedTextColor="?attr/colorPrimary"
                    app:tabIndicatorFullWidth="false"
                    app:tabGravity="fill"
                    app:tabMaxWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_keymap">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_simple" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_custom" />
                </com.google.android.material.tabs.TabLayout>

                <!-- Simple mode: Col1=AB+XY stacked, Col2=swap sticks -->
                <LinearLayout
                    android:id="@+id/layout_simple_mode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tab_mode">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="start">
                        <Switch android:id="@+id/switch_invertAB" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A⇌B" android:paddingStart="0dp" android:paddingEnd="0dp" android:minWidth="0dp" />
                        <Switch android:id="@+id/switch_invertXY" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X⇌Y" android:paddingStart="0dp" android:paddingEnd="0dp" android:minWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end">
                        <Switch android:id="@+id/switch_swap_sticks_simple" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/swap_sticks" android:paddingStart="0dp" android:paddingEnd="0dp" android:minWidth="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Custom mode: 3 pairs per row, SELECT/START on last row -->
                <LinearLayout
                    android:id="@+id/layout_custom_mode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tab_mode">

                    <!-- Col 1=start  Col 2=center  Col 3=end -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="start|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="A" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_A" android:layout_width="52dp" android:layout_height="wrap_content" android:text="A" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="B" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_B" android:layout_width="52dp" android:layout_height="wrap_content" android:text="B" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="X" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_X" android:layout_width="52dp" android:layout_height="wrap_content" android:text="X" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="start|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="Y" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_Y" android:layout_width="52dp" android:layout_height="wrap_content" android:text="Y" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="L" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_L" android:layout_width="52dp" android:layout_height="wrap_content" android:text="L" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="R" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_R" android:layout_width="52dp" android:layout_height="wrap_content" android:text="R" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="start|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="ZL" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_ZL" android:layout_width="52dp" android:layout_height="wrap_content" android:text="ZL" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="ZR" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_ZR" android:layout_width="52dp" android:layout_height="wrap_content" android:text="ZR" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="+↑" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_UP" android:layout_width="52dp" android:layout_height="wrap_content" android:text="+↑" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="start|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="+↓" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_DOWN" android:layout_width="52dp" android:layout_height="wrap_content" android:text="DOWN" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="+←" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_LEFT" android:layout_width="52dp" android:layout_height="wrap_content" android:text="LEFT" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp">
                            <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="+→" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_RIGHT" android:layout_width="52dp" android:layout_height="wrap_content" android:text="RIGHT" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- SELECT/START: 2-col with margin gap -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="start|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginEnd="4dp">
                            <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="SELECT" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_SELECT" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SELECT" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end|center_vertical" android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="4dp">
                            <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="START" android:textSize="15sp" android:textColor="?android:attr/textColorPrimary" android:gravity="end" />
                            <Button android:id="@+id/et_map_START" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="START" android:textSize="13sp" android:clickable="true" android:gravity="center" android:singleLine="true" android:paddingStart="2dp" android:paddingEnd="2dp" android:layout_marginStart="6dp" android:background="@drawable/btn_keymap_bg" android:minHeight="0dp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/barrier_mode_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="layout_custom_mode" />

                <!-- Swap joysticks + Reset defaults row -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/barrier_mode_bottom">

                    <Switch
                        android:id="@+id/switch_swap_sticks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/swap_sticks"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:minWidth="0dp" />

                    <Button
                        android:id="@+id/bt_reset_mapping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reset_defaults"
                        android:textAllCaps="false"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/line2"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#FFCCCCCC"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/group_keymap"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_turbo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"
                app:layout_constraintTop_toBottomOf="@id/line2">

                <TextView
                    android:id="@+id/tv_turbo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_turbo"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <!-- Row 1 -->
                <LinearLayout
                    android:id="@+id/turbo_row1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_turbo">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_A" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="A" />
                        <CheckBox android:id="@+id/cb_turbo_mode_A" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" android:paddingStart="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_B" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="B" />
                        <CheckBox android:id="@+id/cb_turbo_mode_B" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:id="@+id/turbo_row2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/turbo_row1">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_X" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="X" />
                        <CheckBox android:id="@+id/cb_turbo_mode_X" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_Y" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="Y" />
                        <CheckBox android:id="@+id/cb_turbo_mode_Y" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:id="@+id/turbo_row3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/turbo_row2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_L" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="L" />
                        <CheckBox android:id="@+id/cb_turbo_mode_L" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_R" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="R" />
                        <CheckBox android:id="@+id/cb_turbo_mode_R" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 4 -->
                <LinearLayout
                    android:id="@+id/turbo_row4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/turbo_row3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_ZL" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="ZL" />
                        <CheckBox android:id="@+id/cb_turbo_mode_ZL" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">
                        <Switch android:id="@+id/switch_turbo_ZR" android:layout_width="64dp" android:layout_height="wrap_content" android:gravity="start|center_vertical" android:text="ZR" />
                        <CheckBox android:id="@+id/cb_turbo_mode_ZR" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/turbo_mode_short" android:paddingStart="2dp" android:textSize="11sp" android:enabled="false" android:minWidth="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_interval_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/turbo_interval_title"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/turbo_row4" />

                <SeekBar
                    android:id="@+id/sb_turbo_interval"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:min="50"
                    android:max="500"
                    android:progress="60"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/et_turbo_interval"
                    app:layout_constraintTop_toBottomOf="@id/tv_interval_title" />

                <EditText
                    android:id="@+id/et_turbo_interval"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ems="2"
                    android:inputType="number"
                    android:gravity="center"
                    android:minHeight="0dp"
                    android:layout_marginStart="4dp"
                    app:layout_constraintTop_toTopOf="@id/sb_turbo_interval"
                    app:layout_constraintBottom_toBottomOf="@id/sb_turbo_interval"
                    app:layout_constraintEnd_toStartOf="@id/tv_turbo_unit" />

                <TextView
                    android:id="@+id/tv_turbo_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ms"
                    android:textColor="#FF666666"
                    android:gravity="center_vertical"
                    android:layout_marginStart="2dp"
                    app:layout_constraintTop_toTopOf="@id/sb_turbo_interval"
                    app:layout_constraintBottom_toBottomOf="@id/sb_turbo_interval"
                    app:layout_constraintEnd_toEndOf="parent" />

                <Button
                    android:id="@+id/bt_disableturbo"
                    android:layout_width="180dp"
                    android:layout_height="50dp"
                    android:text="@string/bt_txt_disableAllTurbo"
                    android:layout_marginTop="16dp"
                    android:textAllCaps="false"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/sb_turbo_interval" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/line3"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#FFCCCCCC"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/group_turbo"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_specialbt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/group_ip"
                app:layout_constraintEnd_toEndOf="@id/group_ip"
                app:layout_constraintTop_toBottomOf="@+id/line3">

                <TextView
                    android:id="@+id/tv_specialbt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_spBtmap"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sw_txt_home"
                    android:layout_marginTop="10dp"
                    app:layout_constraintEnd_toEndOf="@id/switch_shut"
                    app:layout_constraintTop_toBottomOf="@id/tv_specialbt" />

                <EditText
                    android:id="@+id/et_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/et_home"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textIsSelectable="true"
                    app:layout_constraintStart_toEndOf="@id/switch_home"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_specialbt"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sw_txt_power"
                    android:layout_marginTop="20dp"
                    app:layout_constraintEnd_toEndOf="@id/switch_shut"
                    app:layout_constraintTop_toBottomOf="@id/switch_home" />

                <EditText
                    android:id="@+id/et_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/et_share"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textIsSelectable="true"
                    app:layout_constraintStart_toEndOf="@id/switch_power"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_home"
                    tools:ignore="MissingConstraints" />

                <Switch
                    android:id="@+id/switch_shut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sw_txt_poweroff"
                    android:layout_marginTop="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/switch_power" />

                <EditText
                    android:id="@+id/et_shut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/et_l3r3"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textIsSelectable="true"
                    app:layout_constraintStart_toEndOf="@id/switch_shut"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_power"
                    tools:ignore="MissingConstraints" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_screenoff_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/scrctl_hint"
                android:textColor="#FF888888"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/group_specialbt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Button
                android:id="@+id/bt_offScr"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="30dp"
                android:text="@string/bt_txt_scroff"
                android:textAllCaps="false"
                app:layout_constraintTop_toBottomOf="@+id/tv_screenoff_hint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
